# PitchLab360 Environment Variables

# Anthropic API Key for LLM Text Cleaning and Data Processing
# Obligatorio para el módulo de limpieza y las capas posteriores cualitativas.
ANTHROPIC_API_KEY=sk-ant-api03...

# Modelo de Whisper a usar (base, small, medium). Base recomendado para Railway.
WHISPER_MODEL=base
